# Banco Digital Backend - Variables de entorno
# Copia este archivo como .env y completa los valores reales

# Base de datos (Supabase u otro PostgreSQL)
DB_URL=jdbc:postgresql://<host>:<puerto>/<db>?sslmode=require&prepareThreshold=0
DB_USER=postgres.<project-ref>
DB_PASS=<tu-password>

# Spring
DDL_AUTO=create
SPRING_PROFILES_ACTIVE=seed

# Servidor
PORT=8080

# JWT
JWT_SECRET=BancoDigital2026ClaveSecretaSuperSeguraParaFirmarTokensJWTHS256

# Logs / Seguridad
SHOW_SQL=false
HTTPS_SEGURO=false
CORS_ORIGENES=http://localhost:3000,http://localhost:5173

# Pasarela de pago
GATEWAY_SECRET=clave_secreta_pasarela_banco_2026_hmac
