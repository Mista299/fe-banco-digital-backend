digraph HU01Package {
  rankdir=LR;
  graph [fontname="Helvetica", pad=0.3, nodesep=0.5, ranksep=0.8];
  node [shape=record, style="rounded,filled", fillcolor="#F8FAFC", color="#475569", fontname="Helvetica"];
  edge [color="#64748B", fontname="Helvetica"];

  subgraph cluster_controller {
    label="controller";
    color="#CBD5E1";
    registroController [label="RegistroUsuarioController|+ POST /api/v1/registro\l+ POST /api/v1/registro/validar-identidad\l"];
  }

  subgraph cluster_dto {
    label="dto";
    color="#CBD5E1";
    validarReq [label="ValidarIdentidadRequestDTO|documento\lfechaExpedicion\l"];
    validarRes [label="ValidacionIdentidadResponseDTO|disponible\lmensaje\l"];
    registroReq [label="RegistroNuevoUsuarioRequestDTO|documento\lfechaExpedicion\lnombre\lemail\ldireccion\ltelefono\lusername\lpassword\l"];
    registroRes [label="RegistroNuevoUsuarioResponseDTO|idCliente\lidUsuario\lidCuenta\lnumeroCuenta\lsaldo\lmensaje\l"];
  }

  subgraph cluster_service {
    label="service";
    color="#CBD5E1";
    registroService [label="RegistroUsuarioServiceImpl|validarIdentidad()\lregistrar()\l"];
    numeroCuentaService [label="NumeroCuentaServiceImpl|generarNumeroCuenta()\l"];
  }

  subgraph cluster_repository {
    label="repository";
    color="#CBD5E1";
    clienteRepo [label="ClienteRepository|existsByDocumento()\lexistsByEmail()\lsave()\l"];
    cuentaRepo [label="CuentaRepository|existsByNumeroCuenta()\lsave()\l"];
    usuarioRepo [label="UsuarioRepository|existsByUsername()\lsave()\l"];
    rolRepo [label="RolRepository|findByNombre()\lsave()\l"];
  }

  subgraph cluster_entity {
    label="entity";
    color="#CBD5E1";
    cliente [label="Cliente|documento\lfechaExpedicion\lnombre\lemail\ldireccion\ltelefono\l"];
    cuenta [label="Cuenta|numeroCuenta\ltipo=AHORROS\lestado=ACTIVA\lsaldo=0\l"];
    usuario [label="Usuario|username\lpasswordHash\lestado=ACTIVO\lrol=CLIENTE\l"];
  }

  subgraph cluster_exception {
    label="exception";
    color="#CBD5E1";
    dup [label="IdentificacionDuplicadaException"];
    emailDup [label="EmailYaExisteException"];
    userDup [label="UsuarioYaExisteException"];
    geh [label="GlobalExceptionHandler"];
  }

  registroController -> validarReq;
  registroController -> registroReq;
  registroController -> registroService;
  registroService -> clienteRepo;
  registroService -> cuentaRepo;
  registroService -> usuarioRepo;
  registroService -> rolRepo;
  registroService -> numeroCuentaService;
  registroService -> cliente;
  registroService -> cuenta;
  registroService -> usuario;
  registroService -> validarRes;
  registroService -> registroRes;
  clienteRepo -> dup;
  clienteRepo -> emailDup;
  usuarioRepo -> userDup;
  dup -> geh;
  emailDup -> geh;
  userDup -> geh;
}
